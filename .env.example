# PostgreSQL Database URL (Neon or Vercel Postgres)
DATABASE_URL="postgresql://user:password@host:port/dbname?sslmode=require"

# Auth.js / NextAuth Session Secret & URL
NEXTAUTH_SECRET="generate-a-secure-secret-key"
NEXTAUTH_URL="http://localhost:3000"

# Flutterwave Payment API Keys
FLW_PUBLIC_KEY="FLWPUBK_TEST-..."
FLW_SECRET_KEY="FLWSECK_TEST-..."
FLW_SECRET_HASH="custom-webhook-hash-verification-secret"

# Vercel Blob Storage Token for Image Uploads
BLOB_READ_WRITE_TOKEN="vercel_blob_rw_..."

# Resend API Key for Email Notifications
RESEND_API_KEY="re_..."

# Site URL for SEO / Metadata canonical links
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
